# Copy to .env and fill in real values.



# --- MongoDB ---

# Local:

# MONGO_URI=mongodb://127.0.0.1:27017/meetrix

#

# Atlas (get the exact string from Atlas → Database → Connect → Drivers):

# mongodb+srv://<DB_USER>:<DB_PASSWORD>@<cluster-host>.mongodb.net/<database>?retryWrites=true&w=majority

#

# Important:

# - Replace <DB_PASSWORD> with the database user’s password (not your Atlas login).

# - If the password contains @ # : / ? & you must URL-encode it (e.g. @ → %40).

# - Optional: tune timeouts (ms) if you’re on a slow or mobile network.

MONGO_URI=mongodb://127.0.0.1:27017/meetrix

# MONGO_SERVER_SELECTION_MS=20000

# MONGO_CONNECT_TIMEOUT_MS=20000



# Must be a long random string in production

JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=meetrix-api
JWT_AUDIENCE=meetrix-client



# Mandatory in production (e.g. https://meetrix-app.vercel.app). 
# For local dev, leave unset to allow any origin (mirroring browser).
# FRONTEND_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173



# Optional: start the API + Socket.IO without MongoDB (login/history return 503).

# SKIP_DB=true



PORT=8000
# If npm run dev fails with EADDRINUSE on this port, stop the other Node process or pick a new PORT (and set VITE_SERVER_URL on the frontend to match).

# Socket.IO: max peers per room (default 10, clamped 1–200). Used by src/controllers/socketManager.js
# MAX_PARTICIPANTS=10

# Optional global API rate limit (requests per 15 minutes)
# API_RATE_LIMIT=300

